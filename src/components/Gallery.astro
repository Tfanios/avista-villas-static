---
import { resolveImage, SIZES, type MediaInput } from "../lib/media";

interface GalleryItem {
  image?: MediaInput; // CMS upload object
  src?: string; // legacy / local asset path
  alt: string;
  layout?: string; // CMS: l | p | s
  size?: string; // legacy alias for layout
  height?: string; // h1..h5
}

interface Props {
  titleHtml: string;
  note: string;
  hint: string;
  items: GalleryItem[];
}

const { titleHtml, note, hint, items } = Astro.props;
const resolved = items
  .map((item) => ({ item, img: resolveImage(item.image ?? item.src, item.alt) }))
  .filter((r) => r.img);
---

<section class="section deep" id="gallery">
  <div class="gallery-head">
    <div class="reveal">
      <h2 class="h-section" set:html={titleHtml} />
    </div>
    <p class="body-muted reveal d1">{note}</p>
  </div>
  <div class="carousel-wrap reveal d1">
    <div class="carousel" id="carousel">
      {
        resolved.map(({ item, img }) => (
          <button
            class={`card ${item.layout ?? item.size ?? "l"} ${item.height ?? "h2"}`}
            type="button"
            data-full={img!.src}
            data-thumb={img!.thumbnail}
          >
            <img
              src={img!.thumbnail}
              srcset={img!.srcset}
              sizes={img!.srcset ? SIZES.galleryGrid : undefined}
              alt={item.alt}
              width={img!.width}
              height={img!.height}
              loading="lazy"
              decoding="async"
            />
          </button>
        ))
      }
    </div>
  </div>
  <div class="carousel-ctrl reveal">
    <span class="car-hint">{hint}</span>
  </div>
</section>
