---
interface Props {
  label?: string;
}

const { label = "Avista photo gallery" } = Astro.props;
---

<div
  class="lb"
  id="lb"
  role="dialog"
  aria-modal="true"
  aria-label={label}
  aria-hidden="true"
  tabindex="-1"
>
  <button
    class="x"
    type="button"
    data-close-lightbox
    aria-label="Close photo gallery"
  >
    Close
  </button>
  <button class="nav-arrow prev" type="button" aria-label="Previous image">
    ‹
  </button>
  <img alt="" />
  <button class="nav-arrow next" type="button" aria-label="Next image">
    ›
  </button>
</div>
