---
interface Props {
  label?: string;
}

const { label = "Avista photo gallery" } = Astro.props;
---

<div
  class="gm"
  id="gallery-modal"
  role="dialog"
  aria-modal="true"
  aria-label={`${label} — all photos`}
  aria-hidden="true"
  tabindex="-1"
>
  <header class="gm-bar">
    <button
      class="gm-close"
      type="button"
      data-close-gallery
      aria-label="Close all photos"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          d="M5 5l14 14M19 5L5 19"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"></path>
      </svg>
      <span>Close</span>
    </button>
    <span class="gm-title">All photos</span>
  </header>
  <div class="gm-grid" data-gm-grid></div>
</div>

<div
  class="lb"
  id="lb"
  role="dialog"
  aria-modal="true"
  aria-label={label}
  aria-hidden="true"
  tabindex="-1"
>
  <header class="lb-bar">
    <span class="lb-count">
      <b data-lb-cur>1</b> / <span data-lb-total>1</span>
    </span>
    <button
      class="lb-close"
      type="button"
      data-close-lightbox
      aria-label="Close photo gallery"
    >
      <span>Close</span>
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          d="M5 5l14 14M19 5L5 19"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"></path>
      </svg>
    </button>
  </header>

  <div class="lb-scroll" data-lb-scroll tabindex="0"></div>
</div>
