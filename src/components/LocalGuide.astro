---
interface Place {
  name: string;
  description: string;
  area: string;
  href: string;
}

interface Category {
  title: string;
  description: string;
  places: Place[];
}

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
---

<section class="section local-guide" id="local-guide">
  <div class="wrap">
    <header class="local-guide-head">
      <h2 class="h-section reveal">A few places<br /><em>to begin.</em></h2>
      <div class="reveal d1">
        <p class="body-muted">
          A short local list for swimming, lunch and an easy drink by the water.
          Ask us for more recommendations during your stay.
        </p>
        <p class="local-guide-note">Each name opens in Google Maps.</p>
      </div>
    </header>

    <div class="local-guide-groups">
      {
        categories.map((category, index) => (
          <section class={`local-guide-group reveal d${Math.min(index + 1, 3)}`}>
            <div class="local-guide-category">
              <h3>{category.title}</h3>
              <p>{category.description}</p>
            </div>

            <ul class="local-guide-list">
              {category.places.map((place) => (
                <li>
                  <a
                    class="local-guide-link"
                    href={place.href}
                    target="_blank"
                    rel="noopener"
                    aria-label={`View ${place.name} in Google Maps`}
                  >
                    <span class="local-guide-place">
                      <strong>{place.name}</strong>
                      <span>{place.description}</span>
                    </span>
                    <span class="local-guide-area">{place.area}</span>
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                      <path
                        d="M7 17L17 7M9 7h8v8"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</section>
