---
interface Props {
  titleHtml: string;
  body: string;
  image: string;
  imageAlt: string;
  facts?: any[];
  deep?: boolean;
  wrapClass?: string;
}

const {
  titleHtml,
  body,
  image,
  imageAlt,
  facts = [],
  deep = false,
  wrapClass = "wrap loc"
} = Astro.props;
const hasContent = !!(titleHtml || body || image || facts.length);
---

{
  hasContent && (
    <section class={`section${deep ? " deep" : ""}`} id={deep ? "location" : undefined}>
      <div class={wrapClass}>
        <div class="reveal">
          {titleHtml && <h2 class="h-section" set:html={titleHtml} />}
          {body && <p class="body-muted" style="margin-top: 1.6rem">{body}</p>}
          {facts.length > 0 && (
            <div class="loc-facts">
              {facts.map((fact: any) => (
                <div class="loc-fact">
                  <div class="n">{fact.value}</div>
                  <div class="l">{fact.label}</div>
                </div>
              ))}
            </div>
          )}
        </div>
        {image && (
          <div class="loc-figure reveal d1">
            <img src={image} alt={imageAlt} />
          </div>
        )}
      </div>
    </section>
  )
}
