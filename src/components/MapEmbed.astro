---
interface Props {
  titleHtml: string;
  body: string;
  query: string;
  title: string;
}

const { titleHtml, body, query, title } = Astro.props;
const src = `https://www.google.com/maps?q=${encodeURIComponent(query)}&z=12&output=embed`;
---

<section class="section bg-2" id="map">
  <div class="wrap">
    <div
      class="gallery-head"
      style="margin-bottom: clamp(28px, 4vw, 52px); padding-inline: 0"
    >
      <div class="reveal">
        <h2 class="h-section" set:html={titleHtml} />
      </div>
      <p class="body-muted reveal d1">{body}</p>
    </div>
    <div
      class="reveal d1"
      style="overflow: hidden; border-radius: var(--radius); aspect-ratio: 16/9; background: var(--bg); box-shadow: 0 18px 36px -30px rgba(20, 18, 14, 0.45);"
    >
      <iframe
        title={title}
        src={src}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        style="width: 100%; height: 100%; border: 0; display: block; filter: grayscale(0.18) contrast(1.02);"
      ></iframe>
    </div>
  </div>
</section>
