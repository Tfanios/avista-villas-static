---
interface Props {
  reviews: any[];
}

const { reviews } = Astro.props;
---

{
  reviews.length > 0 && (
    <section class="section" id="reviews">
      <div class="carousel-wrap reveal d1">
        <div class="carousel reviews" aria-label="Guest reviews">
          {reviews.map((review) => (
            <div class="card review-card">
              <div class="rev-head">
                {review.source && <span class="rev-logo">{review.source}</span>}
                <span class="rev-score" aria-label={`Scored ${review.score} out of 10`}>
                  {review.score}
                </span>
              </div>
              <p class="rev-quote">"{review.quote}"</p>
              <div class="rev-by">
                <span class="rev-name">{review.authorName}</span>
                <span class="rev-meta">
                  {[review.authorLocation, review.date].filter(Boolean).join(" · ")}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
