---
import AmenityGrid from "../components/AmenityGrid.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import CrossLink from "../components/CrossLink.astro";
import Cta from "../components/Cta.astro";
import Gallery from "../components/Gallery.astro";
import Hero from "../components/Hero.astro";
import Lightbox from "../components/Lightbox.astro";
import LocationBlock from "../components/LocationBlock.astro";
import Reviews from "../components/Reviews.astro";
import VideoModal from "../components/VideoModal.astro";
import { getProperties } from "../lib/cms";

export async function getStaticPaths() {
  const properties = await getProperties();
  return properties.map((property) => ({
    params: { slug: property.slug },
    props: { property }
  }));
}

const { property } = Astro.props;
---

<BaseLayout
  title={property.seo.title}
  description={property.seo.description}
  currentPath={property.slug}
  preloadImage={property.hero.imageDesktop}
>
  <Hero hero={property.hero} />

  {
    (property.detail.titleHtml ||
      property.detail.body ||
      property.detail.image ||
      property.amenities.length > 0) && (
      <section class="section bg-2" id="spaces">
        <div class="wrap">
          {(property.detail.titleHtml || property.detail.body || property.detail.image) && (
            <div class="loc">
              <div class="reveal">
                {property.detail.titleHtml && (
                  <h2 class="h-section" set:html={property.detail.titleHtml} />
                )}
                {property.detail.body && (
                  <p class="body-muted" style="margin-top: 1.6rem">
                    {property.detail.body}
                  </p>
                )}
              </div>
              {property.detail.image && (
                <div class="loc-figure reveal d1">
                  <img src={property.detail.image} alt={property.detail.imageAlt} />
                </div>
              )}
            </div>
          )}

          {property.amenities.length > 0 && <AmenityGrid amenities={property.amenities} />}
        </div>
      </section>
    )
  }

  <Gallery
    titleHtml={property.galleryTitleHtml}
    note={property.galleryNote}
    hint={property.galleryHint}
    items={property.gallery}
  />

  <Reviews reviews={property.reviews} />

  <LocationBlock
    titleHtml={property.location.titleHtml}
    body={property.location.body}
    image={property.location.image}
    imageAlt={property.location.imageAlt}
    facts={property.location.facts}
    deep
  />

  {
    property.crossLink && (
      <section class="section wrap">
        <CrossLink link={property.crossLink} flip={property.order % 2 === 0} />
      </section>
    )
  }

  <Cta cta={property.cta} />

  <Fragment slot="overlays">
    {property.gallery.length > 0 && <Lightbox label={property.name} />}
    {property.filmUrl && <VideoModal src={property.filmUrl} label={property.name} />}
  </Fragment>
</BaseLayout>
