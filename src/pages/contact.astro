---
import BaseLayout from "../layouts/BaseLayout.astro";
import EnquiryForm from "../components/EnquiryForm.astro";
import Hero from "../components/Hero.astro";
import MapEmbed from "../components/MapEmbed.astro";
import { getContactPage, getSiteSettings } from "../lib/cms";

const contactPage = await getContactPage();
const siteSettings = await getSiteSettings();
---

<BaseLayout
  title={contactPage.seo.title}
  description={contactPage.seo.description}
  currentPath="contact"
  preloadImage={contactPage.hero.imageDesktop}
>
  <Hero hero={contactPage.hero} />

  <section class="section wrap">
    <div class="loc enquiry">
      <div class="reveal">
        <h2 class="h-section" set:html={contactPage.intro.titleHtml} />
        <p class="body-muted" style="margin-top: 1.6rem">
          {contactPage.intro.body}
        </p>

        <dl class="enquiry-contacts">
          <div class="enquiry-contact">
            <dt>Email</dt>
            <dd>
              <a href={`mailto:${siteSettings.contactEmail}`}>{siteSettings.contactEmail}</a>
            </dd>
          </div>
          <div class="enquiry-contact">
            <dt>Phone</dt>
            <dd>
              <a href={`tel:${siteSettings.contactPhone.replace(/\s/g, "")}`}>
                {siteSettings.contactPhone}
              </a>
            </dd>
          </div>
          <div class="enquiry-contact">
            <dt>Estate</dt>
            <dd set:html={siteSettings.addressHtml.replace("<br />", "<br />Sithonia · ")} />
          </div>
        </dl>
      </div>

      <div class="reveal d1">
        <EnquiryForm />
      </div>
    </div>
  </section>

  <MapEmbed
    titleHtml={contactPage.map.titleHtml}
    body={contactPage.map.body}
    location={contactPage.map.location}
    title={contactPage.map.title}
  />
</BaseLayout>
