---
import BaseLayout from "../layouts/BaseLayout.astro";
import Cta from "../components/Cta.astro";
import Gallery from "../components/Gallery.astro";
import Hero from "../components/Hero.astro";
import Lightbox from "../components/Lightbox.astro";
import LocationBlock from "../components/LocationBlock.astro";
import VideoModal from "../components/VideoModal.astro";
import VillaFeature from "../components/VillaFeature.astro";
import { getHomePage, getProperties, getSiteSettings } from "../lib/cms";

const homePage = await getHomePage();
const properties = await getProperties();
const siteSettings = await getSiteSettings();
const hasIntro = !!(homePage.intro.lead || homePage.intro.statement);

// The villas section is framed by the `home` global's `villas` group. When it
// names featured villas, honor that selection/order; otherwise show them all.
const villaList =
  homePage.villas.featuredSlugs.length > 0
    ? homePage.villas.featuredSlugs
        .map((slug: string) => properties.find((property: any) => property.slug === slug))
        .filter(Boolean)
    : properties;
const hasVillasHeader = !!(
  homePage.villas.kicker ||
  homePage.villas.titleHtml ||
  homePage.villas.body
);
---

<BaseLayout
  title={homePage.seo.title}
  description={homePage.seo.description}
  currentPath="home"
  preloadImage={homePage.hero.imageDesktop}
>
  <Hero hero={homePage.hero} />

  {
    hasIntro && (
      <section class="section intro wrap">
        {homePage.intro.lead && <p class="lead reveal d1">{homePage.intro.lead}</p>}
        {homePage.intro.lead && homePage.intro.statement && <div class="rule reveal d1" />}
        {homePage.intro.statement && (
          <p class="statement reveal d2">{homePage.intro.statement}</p>
        )}
      </section>
    )
  }

  {
    villaList.length > 0 && (
      <section class="section bg-2" id="villas">
        <div class="wrap">
          {hasVillasHeader && (
            <header class="villas-head reveal">
              {homePage.villas.kicker && <p class="section-note">{homePage.villas.kicker}</p>}
              {homePage.villas.titleHtml && (
                <h2 class="h-section" set:html={homePage.villas.titleHtml} />
              )}
              {homePage.villas.body && (
                <p class="body-muted" style="margin-top: 1.6rem">
                  {homePage.villas.body}
                </p>
              )}
            </header>
          )}
          {villaList.map((property: any, index: number) => (
            <>
              {index > 0 && (
                <div
                  class="rule h reveal"
                  style="margin-block: clamp(56px, 8vw, 120px)"
                />
              )}
              <VillaFeature property={property} flip={index % 2 === 1} />
            </>
          ))}
        </div>
      </section>
    )
  }

  <Gallery
    titleHtml={homePage.galleryTitleHtml}
    note={homePage.galleryNote}
    hint={homePage.galleryHint}
    items={homePage.gallery}
  />

  <!-- <section class="section bg-2" id="experience">
    <div class="wrap exp">
      <div class="exp-figure reveal">
        <img src={homePage.services.image} alt={homePage.services.imageAlt} />
      </div>
      <div class="reveal d1">
        <p class="section-note">{homePage.services.note}</p>
        <h2 class="h-section" style="margin-top: 1.1rem" set:html={homePage.services.titleHtml} />
        <ol class="exp-list">
          {
            homePage.services.items.map((item) => (
              <li>
                <span class="ix">{item.label}</span>
                <div>
                  <div class="et">{item.title}</div>
                  <div class="ed">{item.description}</div>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section> -->

  <LocationBlock
    titleHtml={homePage.location.titleHtml}
    body={homePage.location.body}
    image={homePage.location.image}
    imageAlt={homePage.location.imageAlt}
    facts={homePage.location.facts}
    deep
  />

  <Cta cta={homePage.cta} />

  <Fragment slot="overlays">
    {homePage.gallery.length > 0 && <Lightbox label={siteSettings.brand} />}
    {siteSettings.estateFilmUrl && (
      <VideoModal src={siteSettings.estateFilmUrl} label={siteSettings.brand} />
    )}
  </Fragment>
</BaseLayout>
