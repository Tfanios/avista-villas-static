---
import BaseLayout from "../layouts/BaseLayout.astro";
import Cta from "../components/Cta.astro";
import Hero from "../components/Hero.astro";
import LocalGuide from "../components/LocalGuide.astro";
import LocationBlock from "../components/LocationBlock.astro";
import MapEmbed from "../components/MapEmbed.astro";
import VideoModal from "../components/VideoModal.astro";
import { getLocationPage, getSiteSettings } from "../lib/cms";

const locationPage = await getLocationPage();
const siteSettings = await getSiteSettings();
---

<BaseLayout
  title={locationPage.seo.title}
  description={locationPage.seo.description}
  currentPath="location"
  preloadImage={locationPage.hero.imageDesktop}
>
  <Hero hero={locationPage.hero} />

  <LocationBlock
    titleHtml={locationPage.overview.titleHtml}
    body={locationPage.overview.body}
    image={locationPage.overview.image}
    imageAlt={locationPage.overview.imageAlt}
    facts={locationPage.overview.facts}
  />

  <MapEmbed
    titleHtml={locationPage.map.titleHtml}
    body={locationPage.map.body}
    location={locationPage.map.location}
    title={locationPage.map.title}
  />

  <LocalGuide guide={locationPage.localGuide} />

  <Cta cta={locationPage.cta} />

  <Fragment slot="overlays">
    {siteSettings.estateFilmUrl && (
      <VideoModal src={siteSettings.estateFilmUrl} label={siteSettings.brand} />
    )}
  </Fragment>
</BaseLayout>
