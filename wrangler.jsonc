{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "avista-villas-static",
  "compatibility_date": "2026-05-31",
  "observability": {
    "enabled": true
  },
  "assets": {
    // Astro builds the static site here. Must point at the build output, NOT the repo root.
    "directory": "./dist"
  }
}
